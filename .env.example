# Shopify Storefront API — copy to `.env.local` and fill in to go live.
# When these are unset, the storefront runs on its bundled demo catalog and the
# checkout button explains that demo mode is active.

# Your store domain, e.g. esmee.myshopify.com (or a custom Storefront domain)
VITE_SHOPIFY_STORE_DOMAIN=

# Public Storefront API access token
# Shopify admin → Settings → Apps and sales channels → Develop apps →
#   <your app> → API credentials → Storefront API access token
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Optional — Storefront API version (defaults to 2025-04)
VITE_SHOPIFY_API_VERSION=2025-04

# Handle of the Manduraa product (defaults to "manduraa")
VITE_SHOPIFY_PRODUCT_HANDLE=manduraa

# Optional — comma-separated handles of upsell/add-on products
VITE_SHOPIFY_ADDON_HANDLES=kupfer-set,manduraa-bundle

# Optional — a Shopify discount code applied to every checkout, so the
# storefront's promotional pricing is honoured. Create a matching code/automatic
# discount in Shopify admin first.
# VITE_SHOPIFY_DISCOUNT_CODE=
